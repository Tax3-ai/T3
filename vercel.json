{
  "crons": [
    {
      "path": "/api/cron/daily?slot=morning",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/daily?slot=midday",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/daily?slot=evening",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/metrics",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/report",
      "schedule": "0 8 * * 1"
    }
  ]
}
